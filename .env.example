# Coin Market Cap free-tier API key (https://coinmarketcap.com/api/).
CMC_API_KEY=replace-me

# RDS Postgres (master or app user that can write to public.cryptocurrencies).
PG_HOST=your-instance.xxxxxx.us-east-1.rds.amazonaws.com
PG_PORT=5432
PG_DATABASE=cdc
PG_USER=cdc_app
PG_PASSWORD=replace-me

# Debezium's Postgres user (separate from the app user; has REPLICATION privilege).
# Referenced by infra/connectors/postgres-source.json, not by the Python script.
DEBEZIUM_PG_PASSWORD=replace-me

# Target S3 bucket for CDC JSON (referenced by infra/connectors/s3-sink.json).
S3_BUCKET=cdc-pipeline-events
AWS_REGION=us-east-1
